{
  "name": "luna-vtuber",
  "version": "2.0.0",
  "description": "Luna — VTuber assistente local com Ollama",
  "main": "frontend/main.js",
  "scripts": {
    "start": "electron . --dev",
    "start:prod": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.local.luna",
    "productName": "Luna",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    },
    "files": [
      "frontend/**/*",
      "backend/**/*",
      "assets/**/*"
    ]
  },
  "dependencies": {
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
